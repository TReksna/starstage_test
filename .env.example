# StarSage environment variables
# Copy this file to .env and fill in your values

# FastAPI
DEBUG=false

# Database (defaults to local SQLite)
DATABASE_URL=sqlite:///./starsage.sqlite3

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Model selection
DEFAULT_FAST_MODEL=gpt-4o-mini
DEFAULT_REASONING_MODEL=gpt-4o

# Pipeline flags
ENABLE_CRITIC_PASS=false
ENABLE_KB_RETRIEVAL=true

# Google Maps (for geocoding / timezone lookup)
GOOGLE_MAPS_API_KEY=

# Legacy / optional (not required for local astrology)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_BLOB_CONTAINER=astro-data
FIREWORKS_API_KEY=
